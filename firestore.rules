rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Running Dinner events
    match /runningDinners/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.organizerId;

      // Teams subcollection
      match /teams/{teamId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null
          && (request.auth.uid == resource.data.member1Id
              || request.auth.uid == get(/databases/$(database)/documents/runningDinners/$(eventId)).data.organizerId);
      }
    }

    // Dinner documents
    match /dinners/{dinnerId} {
      // Anyone can read dinners
      allow read: if true;

      // Only authenticated users can create
      allow create: if request.auth != null;

      // Host can update or delete; authenticated users can update (e.g. join/leave)
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.hostId;
    }
  }
}
