rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    function isOptionalString(data, key, maxLen) {
      return !(key in data) || data[key] == null || isValidString(data[key], maxLen);
    }

    // True if the only fields changed between resource and request.resource
    // are contained in the given set.
    function onlyChanged(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // True if, for a list field, the only change is adding or removing exactly `uid`.
    function selfToggleInList(field, uid) {
      let before = field in resource.data && resource.data[field] is list
        ? resource.data[field] : [];
      let after = field in request.resource.data && request.resource.data[field] is list
        ? request.resource.data[field] : [];
      return before == after
        || after.toSet().difference(before.toSet()).hasOnly([uid])
        || before.toSet().difference(after.toSet()).hasOnly([uid]);
    }

    // ---------- Users ----------
    match /users/{userId} {
      // Only authenticated users can read profiles
      allow read: if isSignedIn();

      // Owner can create their own profile; immutable fields must match
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && isOptionalString(request.resource.data, 'displayName', 100)
        && isOptionalString(request.resource.data, 'bio', 1000)
        && isOptionalString(request.resource.data, 'instagram', 30)
        && isOptionalString(request.resource.data, 'address', 500)
        && isOptionalString(request.resource.data, 'city', 100)
        && isOptionalString(request.resource.data, 'postalCode', 20)
        && isOptionalString(request.resource.data, 'country', 10);

      // Owner can update, but cannot change uid / email / createdAt
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['uid', 'email', 'createdAt']) == false
        && isOptionalString(request.resource.data, 'displayName', 100)
        && isOptionalString(request.resource.data, 'bio', 1000)
        && isOptionalString(request.resource.data, 'instagram', 30)
        && isOptionalString(request.resource.data, 'address', 500)
        && isOptionalString(request.resource.data, 'city', 100)
        && isOptionalString(request.resource.data, 'postalCode', 20)
        && isOptionalString(request.resource.data, 'country', 10);

      allow delete: if isOwner(userId);

      // Private subcollection: sensitive address details (street / house number).
      // Only the owner may read or write their own private data.
      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ---------- Dinners ----------
    match /dinners/{dinnerId} {
      // Public read (discovery pages are open)
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.hostId == request.auth.uid
        && isValidString(request.resource.data.title, 100)
        && isValidString(request.resource.data.description, 2000)
        && isValidString(request.resource.data.location, 200)
        && request.resource.data.date is string
        && request.resource.data.maxGuests is number
        && request.resource.data.maxGuests > 0
        && request.resource.data.maxGuests <= 50;

      // Host: full update (except changing hostId)
      // Non-host: may ONLY toggle themselves in guests / pendingGuests,
      // and must not exceed maxGuests.
      allow update: if isSignedIn() && (
        (
          request.auth.uid == resource.data.hostId
          && request.resource.data.hostId == resource.data.hostId
          && isOptionalString(request.resource.data, 'title', 100)
          && isOptionalString(request.resource.data, 'description', 2000)
          && isOptionalString(request.resource.data, 'location', 200)
        )
        ||
        (
          request.auth.uid != resource.data.hostId
          && onlyChanged(['guests', 'pendingGuests'])
          && selfToggleInList('guests', request.auth.uid)
          && selfToggleInList('pendingGuests', request.auth.uid)
          && (
            !('guests' in request.resource.data)
            || !(request.resource.data.guests is list)
            || request.resource.data.guests.size() <= resource.data.maxGuests
          )
        )
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.hostId;

      // Private subcollection: sensitive dinner details (exact street address).
      // Read: host or already-approved guest.
      // Write: host only.
      match /private/{docId} {
        allow read: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/dinners/$(dinnerId)).data.hostId
          || (request.auth.uid in get(/databases/$(database)/documents/dinners/$(dinnerId)).data.guests)
        );
        allow write: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/dinners/$(dinnerId)).data.hostId
          && isOptionalString(request.resource.data, 'street', 200);
      }

      // Chat messages — any signed-in user (app enforces participant UI)
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && isValidString(request.resource.data.text, 500);
        allow update: if false;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }

      // Ratings — one per user
      match /ratings/{ratingId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.stars is number
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5
          && isOptionalString(request.resource.data, 'comment', 1000);
        allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }

    // ---------- Running Dinners ----------
    match /runningDinners/{eventId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.organizerId == request.auth.uid
        && isValidString(request.resource.data.title, 100)
        && isValidString(request.resource.data.description, 2000)
        && isValidString(request.resource.data.city, 100);

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.organizerId
        && request.resource.data.organizerId == resource.data.organizerId;

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.organizerId;

      // Teams subcollection
      match /teams/{teamId} {
        allow read: if true;

        allow create: if isSignedIn()
          && request.resource.data.member1Id == request.auth.uid
          && isOptionalString(request.resource.data, 'address', 500)
          && isOptionalString(request.resource.data, 'country', 10)
          && isOptionalString(request.resource.data, 'member1Name', 100)
          && isOptionalString(request.resource.data, 'member2Name', 100);

        allow update: if isSignedIn() && (
          request.auth.uid == resource.data.member1Id
          || request.auth.uid == get(/databases/$(database)/documents/runningDinners/$(eventId)).data.organizerId
        );

        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.member1Id
          || request.auth.uid == get(/databases/$(database)/documents/runningDinners/$(eventId)).data.organizerId
        );
      }
    }
  }
}
